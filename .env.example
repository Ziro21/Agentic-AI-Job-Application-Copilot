# ============================================================================
# Agentic AI Job Application Copilot - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# .env is GITIGNORED - keep secrets safe!
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://job_user:job_password@localhost:5432/job_copilot_db

# Database pool settings (optional, defaults are fine for MVP)
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# GREENHOUSE API CONFIGURATION
# ============================================================================
# Enable/disable Greenhouse job discovery
GREENHOUSE_ENABLED=true

# Request timeout (seconds)
GREENHOUSE_REQUEST_TIMEOUT=30

# More explicit timeouts (recommended for reliability).
# connect: TCP/TLS handshake; read: server response time.
# If set, these take precedence over GREENHOUSE_REQUEST_TIMEOUT.
GREENHOUSE_CONNECT_TIMEOUT=10
GREENHOUSE_READ_TIMEOUT=30

# Max retries per board request (default: 3)
GREENHOUSE_MAX_RETRIES=3

# Include full job content in list fetch. If you see stalls/timeouts, set to false.
GREENHOUSE_INCLUDE_CONTENT=true

# Rate limiting: delay between requests (seconds)
GREENHOUSE_REQUEST_DELAY=1.0

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location (optional)
LOG_FILE=logs/job_copilot.log

# ============================================================================
# SCHEDULER CONFIGURATION
# ============================================================================
# Enable/disable automated job discovery scheduler
SCHEDULER_ENABLED=true

# Default daily run time (UTC, format: HH:MM) — used by scheduler.daemon only
SCHEDULER_TIME_UTC=06:30

# ============================================================================
# ALERTS (optional — failed / partial ingest)
# ============================================================================
# HTTPS webhook URL (Slack incoming webhook, Discord, generic HTTPS). POST after run.
# Payload never includes secrets. Use ALERT_WEBHOOK_FORMAT=slack for Slack webhooks.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# ALERT_MIN_ERRORS=1
# ALERT_WEBHOOK_FORMAT=json
# ALERT_WEBHOOK_TIMEOUT=15

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Application environment: development, testing, production
APP_ENV=development

# Enable debug mode (verbose logging, hot reload)
DEBUG=false

# ============================================================================
# OPTIONAL: API KEYS FOR FUTURE FEATURES
# ============================================================================
# Leave blank for MVP; add when implementing external APIs
# OPENAI_API_KEY=
# GOOGLE_SEARCH_API_KEY=
# LINKEDIN_API_TOKEN=
